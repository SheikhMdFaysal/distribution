# Enterprise AI Security Red Teaming Platform
# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_security_db

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys (Optional - needed for real model testing)
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Model Configuration
OPENAI_MODEL=gpt-4
ANTHROPIC_MODEL=claude-3-opus-20240229
GOOGLE_MODEL=gemini-1.5-pro

# Local Models (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Security
SECRET_KEY=your-secret-key-change-in-production
API_KEYS=demo-api-key-123,production-key-456

# CORS
FRONTEND_URL=http://localhost:3000

# Application
DEBUG=true
